{
  "name": "flowtica-react",
  "private": true,
  "sideEffects": false,
  "version": "2026.1.2",
  "type": "module",
  "scripts": {
    "// ── 开发 ──": "",
    "dev": "shopify hydrogen dev --codegen",
    "debug": "shopify hydrogen dev --codegen --debug",
    "preview": "shopify hydrogen preview --build",
    "// ── 构建 ──": "",
    "build": "shopify hydrogen build --codegen",
    "build:express": "cross-env EXPRESS_MODE=1 react-router typegen && cross-env EXPRESS_MODE=1 react-router build",
    "codegen": "shopify hydrogen codegen && react-router typegen",
    "gen:routes": "react-router typegen",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint . --fix --quiet",
    "clean": "rm -rf dist build .react-router node_modules/.cache",
    "// ── 部署 ──": "",
    "start:node": "node workers-server.mjs",
    "start:express": "node server.express.mjs",
    "deploy": "shopify hydrogen deploy",
    "deploy:cf": "pnpm build && wrangler deploy",
    "// ── Cloudflare Workers ──": "",
    "logs:cf": "wrangler tail",
    "dev:cf": "wrangler dev",
    "// ── Shopify CLI ──": "",
    "setup": "shopify hydrogen setup",
    "link": "shopify hydrogen link",
    "unlink": "shopify hydrogen unlink",
    "env:pull": "shopify hydrogen env pull",
    "env:list": "shopify hydrogen env list"
  },
  "dependencies": {
    "@react-router/express": "7.12.0",
    "@react-router/node": "7.12.0",
    "@shopify/hydrogen": "2026.1.2",
    "compression": "^1.8.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "graphql": "^16.10.0",
    "graphql-tag": "^2.12.6",
    "isbot": "^5.1.22",
    "morgan": "^1.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "7.12.0",
    "react-router-dom": "7.12.0",
    "tailwindcss": "^4.1.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@eslint-react/eslint-plugin": "^2.0.6",
    "@graphql-codegen/cli": "5.0.2",
    "@jl-org/js-to-style": "^1.0.1",
    "@react-router/dev": "7.12.0",
    "@react-router/fs-routes": "7.12.0",
    "@shopify/cli": "3.91.1",
    "@shopify/hydrogen-codegen": "0.3.3",
    "@shopify/mini-oxygen": "4.0.1",
    "@shopify/oxygen-workers-types": "^4.1.6",
    "@tailwindcss/vite": "^4.1.6",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/compression": "^1.8.1",
    "@types/morgan": "^1.9.10",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-react-refresh": "^0.4.23",
    "globals": "^15.14.0",
    "graphql-config": "^5.0.3",
    "react-grab": "^0.1.28",
    "vite": "^6.2.4",
    "vite-tsconfig-paths": "^4.3.1",
    "wrangler": "^4.76.0"
  },
  "engines": {
    "node": "^22 || ^24"
  },
  "browserslist": [
    "defaults"
  ]
}